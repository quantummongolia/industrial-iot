// Wi-Fi — нөөц сүлжээ (Photon). Үндсэнд холбогдож/Firebase рүү өгөгдөл явуулж
// чадахгүй үед л энд шилжинэ. Хэрэггүй бол хоосон орхиж болно.
#define WIFI_SSID2     "Photon"
#define WIFI_PASSWORD2 "your_backup_wifi_password"

// Firebase — Email/Password Authentication
// Firebase Console → Authentication → Users → Add User
