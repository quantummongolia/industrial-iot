{
  "rules": {
    ".read": false,
    ".write": false,

    "otp_codes": {
      ".read": false,
      ".write": false
    },

    "flow_system": {
      ".read": "auth != null && (auth.token.allowed === true || auth.token.email === 'mresource-teerem@iot.com')",
      ".write": "auth != null && auth.token.email === 'mresource-teerem@iot.com'",
      "flowmeter1": {
        "flow_rate":  { ".validate": "newData.isNumber()" },
        "totalizer":  { ".validate": "newData.isNumber()" }
      },
      "flowmeter2": {
        "flow_rate":  { ".validate": "newData.isNumber()" },
        "totalizer":  { ".validate": "newData.isNumber()" }
      },
      "flowmeter3": {
        "flow_rate":  { ".validate": "newData.isNumber()" },
        "totalizer":  { ".validate": "newData.isNumber()" }
      },
      "level_sensor": {
        "level": { ".validate": "newData.isNumber()" },
        "mount_height": { ".validate": "newData.isNumber()" }
      },
      "last_updated": { ".validate": "newData.isNumber()" }
    },

    "teerem": {
      ".read": "auth != null && (auth.token.allowed === true || auth.token.email === 'mresource-teerem@iot.com')",
      ".write": "auth != null && auth.token.email === 'mresource-teerem@iot.com'",
      "weight_rate":   { ".validate": "newData.isNumber()" },
      "cumulative_kg": { ".validate": "newData.isNumber()" },
      "feed_water1": {
        "flow_rate": { ".validate": "newData.isNumber()" },
        "totalizer": { ".validate": "newData.isNumber()" }
      },
      "feed_water2": {
        "flow_rate": { ".validate": "newData.isNumber()" },
        "totalizer": { ".validate": "newData.isNumber()" }
      },
      "water_tank": {
        "level": { ".validate": "newData.isNumber()" },
        "mount_height": { ".validate": "newData.isNumber()" }
      },
      "last_updated":  { ".validate": "newData.isNumber()" }
    },

    "butluur": {
      ".read": "auth != null && (auth.token.allowed === true || auth.token.email === 'mresource-teerem@iot.com')",
      ".write": "auth != null && auth.token.email === 'mresource-teerem@iot.com'",
      "weight_rate":   { ".validate": "newData.isNumber()" },
      "cumulative_t":  { ".validate": "newData.isNumber()" },
      "last_updated":  { ".validate": "newData.isNumber()" }
    },

    "pressfilter": {
      ".read": "auth != null && (auth.token.allowed === true || auth.token.email === 'mresource-teerem@iot.com')",
      ".write": "auth != null && auth.token.email === 'mresource-teerem@iot.com'",
      "bayan_tank": {
        "level": { ".validate": "newData.isNumber()" },
        "mount_height": { ".validate": "newData.isNumber()" }
      },
      "clean_water_tank": {
        "level": { ".validate": "newData.isNumber()" },
        "mount_height": { ".validate": "newData.isNumber()" }
      },
      "last_updated": { ".validate": "newData.isNumber()" }
    },

    "energy_meters": {
      ".read": "auth != null && (auth.token.allowed === true || auth.token.email === 'mresource-teerem@iot.com')",
      ".write": "auth != null && auth.token.email === 'mresource-teerem@iot.com'",
      "$meter": {
        "power_kw":         { ".validate": "newData.isNumber()" },
        "total_energy_kwh": { ".validate": "newData.isNumber()" },
        "current_a":        { ".validate": "newData.isNumber()" },
        "current_b":        { ".validate": "newData.isNumber()" },
        "current_c":        { ".validate": "newData.isNumber()" }
      }
    },

    "admins": {
      ".read":  "auth != null && root.child('admins').child(auth.token.email.replace('.', '_').replace('@', '_at_')).val() != null",
      ".write": false
    },

    "firmware": {
      ".read": "auth != null && (auth.token.allowed === true || auth.token.email === 'mresource-teerem@iot.com')",
      ".write": false,
      "$module": {
        "latest": {
          "version":      { ".validate": "newData.isString()" },
          "url":          { ".validate": "newData.isString()" },
          "sha256":       { ".validate": "newData.isString()" },
          "size":         { ".validate": "newData.isNumber()" },
          "published_at": { ".validate": "newData.isNumber()" }
        }
      }
    },

    "devices": {
      ".read": "auth != null && (auth.token.allowed === true || auth.token.email === 'mresource-teerem@iot.com')",
      "$deviceId": {
        ".write": "auth != null && auth.token.email === 'mresource-teerem@iot.com'",
        "family":         { ".validate": "newData.isString()" },
        "firmware":       { ".validate": "newData.isString()" },
        "boot_time":      { ".validate": "newData.isNumber()" },
        "reset_reason":   { ".validate": "newData.isString()" },
        "status":         { ".validate": "newData.isString()" },
        "mac":            { ".validate": "newData.isString()" },
        "ip":             { ".validate": "newData.isString()" },
        "partition":      { ".validate": "newData.isString()" },
        "last_heartbeat": { ".validate": "newData.isNumber()" },
        "uptime_s":       { ".validate": "newData.isNumber()" },
        "free_heap":      { ".validate": "newData.isNumber()" },
        "rssi":           { ".validate": "newData.isNumber()" },
        "validated_at":   { ".validate": "newData.isNumber()" },
        "ota_status": {
          "stage":    { ".validate": "newData.isString()" },
          "progress": { ".validate": "newData.isNumber()" },
          "message":  { ".validate": "newData.isString()" },
          "ts":       { ".validate": "newData.isNumber()" },
          "cmd_id":   { ".validate": "newData.isString()" }
        }
      }
    },

    "commands": {
      ".read": "auth != null && (auth.token.allowed === true || auth.token.email === 'mresource-teerem@iot.com')",
      "$deviceId": {
        "pending": {
          ".write": "auth != null && root.child('admins').child(auth.token.email.replace('.', '_').replace('@', '_at_')).val() != null"
        },
        "result": {
          "$cmdId": {
            ".write": "auth != null && auth.token.email === 'mresource-teerem@iot.com'"
          }
        }
      }
    }
  }
}
